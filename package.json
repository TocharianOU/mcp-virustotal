{
  "name": "@tocharianou/mcp-virustotal",
  "description": "VirusTotal MCP Server – security analysis for URLs, files, IPs and domains",
  "version": "1.0.1",
  "mcpName": "io.github.TocharianOU/virustotal",
  "license": "MIT",
  "author": "TocharianOU",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "bin": {
    "mcp-virustotal": "dist/index.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TocharianOU/mcp-virustotal.git"
  },
  "bugs": {
    "url": "https://github.com/TocharianOU/mcp-virustotal/issues"
  },
  "homepage": "https://github.com/TocharianOU/mcp-virustotal#readme",
  "keywords": [
    "virustotal",
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "security",
    "threat-intelligence",
    "malware-analysis",
    "url-scanner",
    "file-analysis",
    "ip-analysis",
    "domain-analysis",
    "soc",
    "claude",
    "anthropic"
  ],
  "files": [
    "dist",
    "logos",
    "LICENSE",
    "README.md",
    "server.json"
  ],
  "scripts": {
    "build": "tsc && shx chmod +x dist/index.js",
    "prepare": "npm run build",
    "watch": "tsc --watch",
    "start": "node dist/index.js",
    "start:http": "MCP_TRANSPORT=http node dist/index.js",
    "inspector": "npx @modelcontextprotocol/inspector node dist/index.js",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "release": "./scripts/create-release.sh",
    "release:npm": "npm run build && tar -czf mcp-virustotal-v$npm_package_version.tar.gz dist logos LICENSE README.md server.json package.json"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.23.0",
    "@types/express": "^5.0.3",
    "axios": "^1.8.4",
    "dotenv": "^16.4.5",
    "express": "^5.1.0",
    "tiktoken": "^1.0.22",
    "zod": "^3.24.2"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@types/jest": "^29.5.0",
    "@types/node": "22.13.15",
    "jest": "^29.7.0",
    "shx": "0.4.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.8.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
